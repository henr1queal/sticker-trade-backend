NODE_ENV=development
PORT=3000
HOST=0.0.0.0

DATABASE_URL=postgresql://sticker:sticker_secret@localhost:5432/sticker_trade?schema=public
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-to-a-random-string-with-at-least-32-characters
JWT_EXPIRES_IN=7d
COOKIE_SECRET=change-me-to-another-random-string-with-at-least-32-chars

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:1420,http://127.0.0.1:1420

ADMIN_API_KEY=change-me-admin-key-min-32-chars-long
# Token opaco na URL (mín. 24 chars). Rotas ops só existem se definido:
# GET /api/ops/{OPS_ROUTE_TOKEN}/metrics
# GET /api/ops/{OPS_ROUTE_TOKEN}/logs
# GET /api/ops/{OPS_ROUTE_TOKEN}/feedback
# Header: X-Ops-Token: {ADMIN_API_KEY}
OPS_ROUTE_TOKEN=change-me-to-a-long-random-token-min-24-chars
# Opcional: restringir por IP (ex.: 127.0.0.1,10.0.0.5)
OPS_ALLOWED_IPS=

RATE_LIMIT_MAX=1000
RATE_LIMIT_TIME_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=60
AUTH_RATE_LIMIT_TIME_WINDOW_MS=60000

REGISTER_MIN_FORM_MS=3000
REGISTER_MAX_FORM_MS=3600000
# Opcional: chave secreta Cloudflare Turnstile (recomendado em produção)
TURNSTILE_SECRET_KEY=

POSTGRES_USER=sticker
POSTGRES_PASSWORD=sticker_secret
POSTGRES_DB=sticker_trade
