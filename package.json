    "@fastify/swagger-ui": "^5.2.6",
    "@prisma/client": "^6.9.0",
    "argon2": "^0.43.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.6.1",
    "nanoid": "^5.1.5",
    "uuid": "^11.1.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
